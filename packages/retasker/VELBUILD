maintainer="Benjamin Istace <benjamin.istace@gmail.com>"
pkgname=retasker
pkgver=1.0.1
pkgrel=0
upstream_author="Benjamin Istace"
category=apps
pkgdesc="Circle handwriting to capture todos; calendar + list viewer with OCR transcription."
url="https://github.com/bistace/retasker"
arch="aarch64"
license="GPL-3.0"
# framebuffer-spy is the soft import the capture extension resolves against; the qmds are
# hashtab-bound to the OS, so pin the reMarkable OS range the hashtab was built for.
depends="appload qt-resource-rebuilder xovi-message-broker framebuffer-spy remarkable-os>=3.27 remarkable-os<3.28"
source="https://github.com/bistace/retasker/releases/download/v$pkgver/retasker-$pkgver-aarch64.tar.gz"
sha512sums="9024e04fa885d1c246bfa15265a9d8b97781460a52f7e38331da1725099e49a5bc2b47fd215a9d006296ee70cf9f1d72bcae5ba13a5f01463538ca3218d69a1c  retasker-$pkgver-aarch64.tar.gz"
options="!check !fhs"

package() {
    local app="$pkgdir/home/root/xovi/exthome/appload/retasker"
    local qrr="$pkgdir/home/root/xovi/exthome/qt-resource-rebuilder"
    local ext="$pkgdir/home/root/xovi/extensions.d"

    install -Dm755 "$srcdir/retasker-capture.so" "$ext/retasker-capture.so"
    install -Dm755 "$srcdir/retasker-backend"    "$app/backend/entry"
    install -Dm644 "$srcdir/retasker-viewer.rcc" "$app/resources.rcc"
    install -Dm644 "$srcdir/manifest.json"       "$app/manifest.json"
    install -Dm644 "$srcdir/icon.png"            "$app/icon.png"
    install -Dm644 "$srcdir/config.example.json" "$app/config.example.json"
    install -d "$app/captures"

    for q in retasker-selection retasker-toolbar retasker-newnote retasker-window; do
        install -Dm644 "$srcdir/$q.qmd" "$qrr/$q.qmd"
    done
}

# Seed config.json only if absent. It is never package-owned, so upgrades never overwrite
# the user's OpenRouter key or model.
postinstall() {
    local app=/home/root/xovi/exthome/appload/retasker
    [ -f "$app/config.json" ] || cp "$app/config.example.json" "$app/config.json"
    cat <<'EOF'
reTasker installed. Add your OpenRouter key + model:
  edit /home/root/xovi/exthome/appload/retasker/config.json   (apiKey, model)
Then reload XOVI:  /home/root/xovi/start
EOF
}

postupgrade() {
    echo "reTasker upgraded — config.json left untouched. Reload: /home/root/xovi/start"
}

# apk removes package-owned files (.so, .qmd, .rcc, manifest, icon) on its own. config.json,
# the SQLite db and captures are not package-owned, so only wipe them on an explicit purge.
postdeinstall() {
    [ "$VELLUM_PURGE" = "1" ] && rm -rf /home/root/xovi/exthome/appload/retasker
    echo "reTasker removed — reload with: /home/root/xovi/start"
}
